{
  "version": 3,
  "overrides": {
    "cart/index.html": {
      "path": "cart"
    },
    "login/index.html": {
      "path": "login"
    },
    "search/index.html": {
      "path": "search"
    },
    "brands/index.html": {
      "path": "brands"
    },
    "checkout/index.html": {
      "path": "checkout"
    },
    "register/index.html": {
      "path": "register"
    },
    "shipping/index.html": {
      "path": "shipping"
    },
    "categories/index.html": {
      "path": "categories"
    },
    "track-order/index.html": {
      "path": "track-order"
    },
    "forgot-password/index.html": {
      "path": "forgot-password"
    },
    "social-callback/index.html": {
      "path": "social-callback"
    },
    "razorpay-callback/index.html": {
      "path": "razorpay-callback"
    },
    "index.html": {
      "path": ""
    },
    "flash-sale/index.html": {
      "path": "flash-sale"
    },
    "seller/sign-up/index.html": {
      "path": "seller/sign-up"
    },
    "user/orders/index.html": {
      "path": "user/orders"
    },
    "user/vouchers/index.html": {
      "path": "user/vouchers"
    },
    "user/addresses/index.html": {
      "path": "user/addresses"
    },
    "user/following/index.html": {
      "path": "user/following"
    },
    "user/wishlists/index.html": {
      "path": "user/wishlists"
    },
    "seller/register/index.html": {
      "path": "seller/register"
    },
    "user/compared/index.html": {
      "path": "user/compared"
    },
    "user/profile/index.html": {
      "path": "user/profile"
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    }
  ]
}